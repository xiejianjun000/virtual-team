{
  "name": "virtualteam",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:push": "pnpm --filter @virtualteam/db db:push",
    "db:studio": "pnpm --filter @virtualteam/db db:studio",
    "db:migrate": "pnpm --filter @virtualteam/db db:migrate",
    "db:seed": "pnpm --filter @virtualteam/db db:seed"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
